{
  "family": "partion-blockchain",
  "containerDefinitions": [
    {
      "name": "blockchain",
      "image": "142731142554.dkr.ecr.ap-northeast-2.amazonaws.com/partion-blockchain:ledger-kafka-fix-202606202240",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "ap-northeast-2"
        },
        {
          "name": "DD_AGENT_HOST",
          "value": "127.0.0.1"
        },
        {
          "name": "DD_VERSION",
          "value": "ledger-kafka-fix-202606202240"
        },
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "prod"
        },
        {
          "name": "DD_TRACE_AGENT_PORT",
          "value": "8126"
        },
        {
          "name": "KAFKA_BOOTSTRAP_SERVERS",
          "value": "b-1.partionmsk.3u9t00.c4.kafka.ap-northeast-2.amazonaws.com:9092,b-2.partionmsk.3u9t00.c4.kafka.ap-northeast-2.amazonaws.com:9092"
        },
        {
          "name": "PARTION_LEDGER_BACKFILL_ENABLED",
          "value": "true"
        },
        {
          "name": "DD_TRACE_SAMPLE_RATE",
          "value": "1.0"
        },
        {
          "name": "JAVA_TOOL_OPTIONS",
          "value": "-javaagent:/app/dd-java-agent.jar"
        },
        {
          "name": "DD_SERVICE",
          "value": "partion-blockchain"
        },
        {
          "name": "DD_LOGS_INJECTION",
          "value": "true"
        },
        {
          "name": "DD_ENV",
          "value": "prod"
        },
        {
          "name": "PARTION_LEDGER_TOPIC",
          "value": "partion.ledger.events"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:142731142554:secret:partion/prod/spring-datasource-url-Rojobw"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:142731142554:secret:partion/prod/spring-datasource-username-rlfYti"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:142731142554:secret:partion/prod/spring-datasource-password-BJyL2t"
        }
      ],
      "dependsOn": [
        {
          "containerName": "datadog-agent",
          "condition": "START"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/partion-blockchain",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    },
    {
      "name": "datadog-agent",
      "image": "public.ecr.aws/datadog/agent:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8126,
          "hostPort": 8126,
          "protocol": "tcp"
        },
        {
          "containerPort": 8125,
          "hostPort": 8125,
          "protocol": "udp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DD_APM_NON_LOCAL_TRAFFIC",
          "value": "true"
        },
        {
          "name": "DD_SITE",
          "value": "ap1.datadoghq.com"
        },
        {
          "name": "ECS_FARGATE",
          "value": "true"
        },
        {
          "name": "DD_APM_ENABLED",
          "value": "true"
        },
        {
          "name": "DD_ENV",
          "value": "prod"
        },
        {
          "name": "DD_LOGS_ENABLED",
          "value": "false"
        },
        {
          "name": "DD_DOGSTATSD_NON_LOCAL_TRAFFIC",
          "value": "true"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "DD_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:142731142554:secret:partion/prod/datadog-api-key-oadhRl"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/partion-blockchain",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "datadog-agent"
        }
      },
      "systemControls": []
    }
  ],
  "taskRoleArn": "arn:aws:iam::142731142554:role/partion-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::142731142554:role/partion-ecs-execution-role",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "2048"
}
