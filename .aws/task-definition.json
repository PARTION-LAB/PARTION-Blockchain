{
  "family": "partion-blockchain",
  "containerDefinitions": [
    {
      "name": "blockchain",
      "image": "__BLOCKCHAIN_IMAGE__",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "__BLOCKCHAIN_AWS_REGION__"
        },
        {
          "name": "DD_AGENT_HOST",
          "value": "__BLOCKCHAIN_DD_AGENT_HOST__"
        },
        {
          "name": "DD_VERSION",
          "value": "__BLOCKCHAIN_DD_VERSION__"
        },
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "__BLOCKCHAIN_SPRING_PROFILES_ACTIVE__"
        },
        {
          "name": "DD_TRACE_AGENT_PORT",
          "value": "__BLOCKCHAIN_DD_TRACE_AGENT_PORT__"
        },
        {
          "name": "KAFKA_BOOTSTRAP_SERVERS",
          "value": "__BLOCKCHAIN_KAFKA_BOOTSTRAP_SERVERS__"
        },
        {
          "name": "PARTION_LEDGER_BACKFILL_ENABLED",
          "value": "__BLOCKCHAIN_PARTION_LEDGER_BACKFILL_ENABLED__"
        },
        {
          "name": "DD_TRACE_SAMPLE_RATE",
          "value": "__BLOCKCHAIN_DD_TRACE_SAMPLE_RATE__"
        },
        {
          "name": "JAVA_TOOL_OPTIONS",
          "value": "__BLOCKCHAIN_JAVA_TOOL_OPTIONS__"
        },
        {
          "name": "DD_SERVICE",
          "value": "__BLOCKCHAIN_DD_SERVICE__"
        },
        {
          "name": "DD_LOGS_INJECTION",
          "value": "__BLOCKCHAIN_DD_LOGS_INJECTION__"
        },
        {
          "name": "DD_ENV",
          "value": "__BLOCKCHAIN_DD_ENV__"
        },
        {
          "name": "PARTION_LEDGER_TOPIC",
          "value": "__BLOCKCHAIN_PARTION_LEDGER_TOPIC__"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_URL",
          "valueFrom": "__SPRING_DATASOURCE_URL_SECRET_ARN__"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "valueFrom": "__SPRING_DATASOURCE_USERNAME_SECRET_ARN__"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "__SPRING_DATASOURCE_PASSWORD_SECRET_ARN__"
        }
      ],
      "dependsOn": [
        {
          "containerName": "datadog-agent",
          "condition": "START"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/partion-blockchain",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    },
    {
      "name": "datadog-agent",
      "image": "public.ecr.aws/datadog/agent:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8126,
          "hostPort": 8126,
          "protocol": "tcp"
        },
        {
          "containerPort": 8125,
          "hostPort": 8125,
          "protocol": "udp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DD_APM_NON_LOCAL_TRAFFIC",
          "value": "__BLOCKCHAIN_DATADOG_DD_APM_NON_LOCAL_TRAFFIC__"
        },
        {
          "name": "DD_SITE",
          "value": "__BLOCKCHAIN_DATADOG_DD_SITE__"
        },
        {
          "name": "ECS_FARGATE",
          "value": "__BLOCKCHAIN_DATADOG_ECS_FARGATE__"
        },
        {
          "name": "DD_APM_ENABLED",
          "value": "__BLOCKCHAIN_DATADOG_DD_APM_ENABLED__"
        },
        {
          "name": "DD_ENV",
          "value": "__BLOCKCHAIN_DATADOG_DD_ENV__"
        },
        {
          "name": "DD_LOGS_ENABLED",
          "value": "__BLOCKCHAIN_DATADOG_DD_LOGS_ENABLED__"
        },
        {
          "name": "DD_DOGSTATSD_NON_LOCAL_TRAFFIC",
          "value": "__BLOCKCHAIN_DATADOG_DD_DOGSTATSD_NON_LOCAL_TRAFFIC__"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "DD_API_KEY",
          "valueFrom": "__DD_API_KEY_SECRET_ARN__"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/partion-blockchain",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "datadog-agent"
        }
      },
      "systemControls": []
    }
  ],
  "taskRoleArn": "__BLOCKCHAIN_TASK_ROLE_ARN__",
  "executionRoleArn": "__BLOCKCHAIN_EXECUTION_ROLE_ARN__",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "2048"
}
